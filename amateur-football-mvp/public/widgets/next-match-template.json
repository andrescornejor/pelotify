{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.6",
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "bleed": true,
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "Image",
                  "url": "${$root.iconUrl}",
                  "size": "Small",
                  "style": "Person"
                }
              ],
              "verticalContentAlignment": "Center"
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "PELOTIFY",
                  "weight": "Bolder",
                  "size": "Small",
                  "color": "Good",
                  "spacing": "None"
                },
                {
                  "type": "TextBlock",
                  "text": "Próximo Partido",
                  "size": "Small",
                  "isSubtle": true,
                  "spacing": "None"
                }
              ],
              "verticalContentAlignment": "Center"
            }
          ],
          "spacing": "Small"
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Medium",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "1",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${$root.teamA}",
                  "weight": "Bolder",
                  "horizontalAlignment": "Center",
                  "size": "Medium",
                  "wrap": true
                }
              ],
              "verticalContentAlignment": "Center",
              "horizontalAlignment": "Center"
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "VS",
                  "weight": "Bolder",
                  "color": "Good",
                  "horizontalAlignment": "Center",
                  "size": "ExtraLarge"
                }
              ],
              "verticalContentAlignment": "Center"
            },
            {
              "type": "Column",
              "width": "1",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${$root.teamB}",
                  "weight": "Bolder",
                  "horizontalAlignment": "Center",
                  "size": "Medium",
                  "wrap": true
                }
              ],
              "verticalContentAlignment": "Center",
              "horizontalAlignment": "Center"
            }
          ]
        },
        {
          "type": "FactSet",
          "facts": [
            {
              "title": "📅 Fecha",
              "value": "${$root.date}"
            },
            {
              "title": "⏰ Hora",
              "value": "${$root.time}"
            },
            {
              "title": "📍 Lugar",
              "value": "${$root.venue}"
            }
          ],
          "spacing": "Medium"
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "${$root.countdown}",
      "weight": "Bolder",
      "color": "Good",
      "horizontalAlignment": "Center",
      "size": "Medium",
      "spacing": "Medium"
    }
  ],
  "actions": [
    {
      "type": "Action.Execute",
      "title": "Ver Detalles",
      "verb": "open-match",
      "data": {
        "matchId": "${$root.matchId}"
      }
    },
    {
      "type": "Action.Execute",
      "title": "Armar Partido",
      "verb": "create-match"
    }
  ]
}
